# Строка подключения к PostgreSQL (Railway создаёт её автоматически при добавлении
# сервиса PostgreSQL в проект — переменная DATABASE_URL в настройках сервиса).
# Локально можно указать свою строку подключения к тестовой базе.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Порт, на котором стартует сервер. Railway подставляет свой PORT автоматически —
# эту переменную можно не задавать в Railway, она нужна только для локального запуска.
PORT=3000

# Включить SSL при подключении к PostgreSQL.
# Railway internal-подключение (DATABASE_URL из того же проекта) SSL не требует — оставьте false.
# Если подключаетесь к базе по публичному хосту/через прокси — поставьте true.
PGSSL=false
